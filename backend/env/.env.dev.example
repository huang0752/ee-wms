# ==================================
# 开发环境配置文件模版:复制此文件为 .env.dev 并修改配置
# ==================================

ENVIRONMENT = "dev"

# 服务器配置
SERVER_HOST = "localhost"     # 允许访问的IP地址
SERVER_PORT = 8001          # 服务端口

# 文档配置
DEBUG = True                        # 调试模式
TITLE = "🎉 FastapiAdmin 🎉 -dev"    # 文档标题
VERSION = "0.1.0"                   # 版本号
SUMMARY = "接口汇总"                 # 文档概述
DOCS_URL = "/docs"                  # Swagger UI路径
REDOC_URL = "/redoc"                # ReDoc路径
ROOT_PATH = "/api/v1"               # API路由前缀
DESCRIPTION = "该项目是一个基于python的web服务框架，基于fastapi和sqlalchemy实现。"  # 文档描述

# 是否启用演示模式
DEMO_ENABLE = False

# 产品能力装配：default/minimal/business-admin/saas-admin，或通过 APP_ASSEMBLY_FILE 指定产品仓库自己的 TOML
APP_ASSEMBLY = "default"
APP_ASSEMBLY_FILE = ""

# 登录认证能力（产品可按需开启）
AUTH_LOGIN_REGISTER_ENABLE = False
AUTH_LOGIN_FORGOT_PASSWORD_ENABLE = True
AUTH_PASSWORD_RESET_MODE = "email_code"  # email_code / legacy_mobile / disabled
AUTH_LOGIN_MOBILE_ENABLE = False
AUTH_LOGIN_QR_ENABLE = False
AUTH_LOGIN_REMEMBER_ME_ENABLE = True
AUTH_LOGIN_DEMO_ACCOUNTS_ENABLE = False

# 数据库配置
DATABASE_TYPE = "mysql"  # mysql、postgres、sqlite、dm(sqlite、dm不支持代码生成)

# 数据库配置
DATABASE_HOST = "localhost"
DATABASE_PORT = 3306  # MySQL:3306 PostgreSQL:5432
DATABASE_USER = "root"
DATABASE_PASSWORD = "your_database_password"
DATABASE_NAME = "fastapiadmin"

# Redis配置
REDIS_ENABLE = True 
REDIS_HOST = "localhost"
REDIS_PORT = 6379
REDIS_USER = ""
REDIS_PASSWORD = "your_redis_password"
REDIS_DB_NAME = 1

# 日志配置
LOGGER_LEVEL = "DEBUG"   # 日志级别

# 第三方 OAuth 登录（默认关闭）
OAUTH_ENABLE = False

# 大模型配置
OPENAI_BASE_URL = "https://api.minimax.chat"
OPENAI_API_KEY = "your_api_key"
OPENAI_MODEL = "deepseek-v4-flash"

# IP 归属地查询（登录时对外请求第三方 API，生产建议关闭）
IP_LOCATION_ENABLE=False

# 【生产】环境变量 - 覆盖通用配置

# 环境标识
VITE_APP_ENV = production

# 项目名称
VITE_APP_TITLE = 电工装备智慧仓储WMS系统v2.0

# API 请求基础路径：生产环境走同域 Nginx 反代 /api/v1
VITE_API_URL = /
VITE_API_BASE_URL = http://127.0.0.1:41232

# 是否删除控制台输出
VITE_DROP_CONSOLE = true

# WebSocket 端点：留空时自动使用当前访问域名（http=>ws, https=>wss）
VITE_APP_WS_ENDPOINT =
